{
  "version": 2,
  "builds": [
    {
      "src": "server-v2.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server-v2.js"
    },
    {
      "src": "/admin.html",
      "dest": "public/admin.html"
    },
    {
      "src": "/chat.html",
      "dest": "public/chat.html"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}