{
  "version": 2,
  "builds": [
    {
      "src": "server-v2.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server-v2.js"
    },
    {
      "src": "/chat.html",
      "dest": "chat.html"
    },
    {
      "src": "/",
      "dest": "index.html"
    },
    {
      "src": "/(.*\\..*)",
      "dest": "$1"
    }
  ]
}
